# 복사해서 .env 로 저장하고 값 채우기:  cp .env.example .env
# 생성+임베딩 = Google AI Studio (Gemini). 키 1개로 동작.
GEMINI_API_KEY=...

# 로컬 Ollama(M2 등) — 그래프 추출/생성용. 예: http://<M2-IP>:11434
OLLAMA_BASE_URL=http://localhost:11434

# Neo4j 그래프 저장소 (docker compose up -d 로 가동 — docker-compose.yml)
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ragbench123
